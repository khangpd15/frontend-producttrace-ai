# ====================================================
# ProductTrace-AI - Environment Configuration
# ====================================================
# Copy file này thành .env.local để chạy local
# KHÔNG commit file .env.local lên git

# Backend API Gateway URL (Kong Gateway)
# Local:      http://localhost:8000/api
# Production: https://api.producttrace.vn/api
VITE_API_URL=

# Socket Server URL (cho tính năng real-time nếu có)
VITE_SOCKET_URL=

# App metadata
VITE_APP_NAME=ProductTrace-AI
VITE_APP_VERSION=1.0.0
